# ─── Gurukul Portal Server – Environment Variables ───────────────────────
# Copy this file to .env and fill in your values

# Server
PORT=3000

# JWT Secret – change this to a long random string in production!
JWT_SECRET=gurukul-high-secret-change-this-in-production

# Admin key for the Admissions Admin panel (change this from the default!)
ADMIN_KEY=gurukul-admin-2026

# ─── Google Sheets Write-back for Admissions (recommended, easy!) ─────────
# Uses Google Apps Script – no billing, no OAuth2 setup needed.
# Open server/SETUP-GOOGLE-SHEETS.html for step-by-step setup instructions.
# Once set, every new admission form submission auto-appears in your Sheet.

APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ─── Google Sheets Read-sync for Student Portal (optional) ────────────────
# Pull student data (attendance, marks, fees) from a public Google Sheet.
# Step 1: Go to https://console.cloud.google.com
# Step 2: Create a project → Enable "Google Sheets API"
# Step 3: Create API Key (Credentials → API Key)
# Step 4: Make your Google Sheet publicly readable (Share → Anyone with link → Viewer)
# Step 5: Paste values below

GOOGLE_SHEET_ID=your-google-sheet-id-here
GOOGLE_API_KEY=your-google-api-key-here

# ─── Google Sheet Structure for student portal sync ───────────────────────
# Sheet must have these 4 tabs with these EXACT column headers:
#
# Tab: Students
#   studentid | name | class | section | dob | parentname | parentphone | username | password
#
# Tab: Attendance
#   studentid | date (YYYY-MM-DD) | status (P/A/L)
#
# Tab: Marks
#   studentid | subject | exam | marks | maxmarks | term | date
#
# Tab: Fees
#   studentid | feetype | amount | duedate | paiddate | status (Paid/Pending) | receipt
